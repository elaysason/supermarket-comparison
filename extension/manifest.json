{
  "manifest_version": 3,
  "name": "סל קל",
  "version": "1.0.1",
  "description": "משווה את סל הקניות שלך בין רשתות נתמכות ומראה איפה משתלם יותר להזמין.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*.shufersal.co.il/*",
    "*://*.rami-levy.co.il/*",
    "*://*.hazi-hinam.co.il/*",
    "https://supermarket-comparison-api-649951889970.europe-west1.run.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.shufersal.co.il/*",
        "*://*.rami-levy.co.il/*",
        "*://*.hazi-hinam.co.il/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "סל קל",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/sal_kal_v1-cropped.png"
      ],
      "matches": [
        "*://*.shufersal.co.il/*",
        "*://*.rami-levy.co.il/*",
        "*://*.hazi-hinam.co.il/*"
      ]
    }
  ]
}
